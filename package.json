{
  "name": "devtools-local-agent-proxy",
  "version": "0.5.0",
  "description": "A token-saving MCP proxy that wraps chrome-devtools-mcp: compresses large diagnostic dumps with a local Ollama model and returns focused, downscaled WebP screenshots before they reach Claude Code.",
  "type": "module",
  "bin": {
    "devtools-local-agent-proxy": "dist/proxy.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/proxy.js",
    "dev": "tsx src/proxy.ts",
    "prepare": "tsc",
    "smoke": "node scripts/smoke.mjs",
    "test:screenshot": "node scripts/screenshot.mjs",
    "test:diagnostics": "node scripts/diagnostics.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "chrome-devtools",
    "ollama",
    "proxy",
    "token-compression",
    "context-window"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
